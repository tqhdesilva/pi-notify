{
  "name": "pi-notify",
  "version": "0.1.0",
  "description": "Pi extension for Ghostty and tmux attention notifications",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "ghostty",
    "tmux",
    "notifications"
  ],
  "license": "MIT",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "pi": {
